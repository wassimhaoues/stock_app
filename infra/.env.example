# Shared StockPro environment file.
# Spring imports this file from backend local dev, Docker Compose uses it for MySQL,
# and the Angular dev proxy reads FRONTEND_PROXY_TARGET from it.

# MySQL container credentials used by infra/docker-compose.yml.
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=stock_app_db
MYSQL_USER=stockpro_user
MYSQL_PASSWORD=change_me_user_password

# Local dev: backend runs on host machine, MySQL runs in Docker and is exposed on 3307.
LOCAL_MYSQL_HOST=127.0.0.1
LOCAL_MYSQL_PORT=3307

# Docker later: backend container reaches MySQL by service name on the Docker network.
DOCKER_MYSQL_HOST=stock-mysql
DOCKER_MYSQL_PORT=3306

# Backend/frontend local dev ports.
BACKEND_PORT=8085
FRONTEND_PORT=4200
FRONTEND_PROXY_TARGET=http://127.0.0.1:8085
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# JPA schema behavior.
# Local/dev can use update. For production prefer validate with managed migrations.
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# JWT and HttpOnly cookie auth.
# Use at least 32 random characters for JWT_SECRET. In production use a secret manager.
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_EXPIRATION_MS=86400000
AUTH_COOKIE_NAME=stockpro_auth
AUTH_COOKIE_PATH=/
AUTH_COOKIE_SAME_SITE=Lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_MAX_AGE_SECONDS=86400

# Seed accounts inserted only if the email does not already exist.
# Local/demo values are acceptable here; production should override or disable seed logic later.
SEED_ADMIN_NOM=Admin StockPro
SEED_ADMIN_EMAIL=admin@stockpro.local
SEED_ADMIN_PASSWORD=change_me_admin_password
SEED_GESTIONNAIRE_NOM=Gestionnaire StockPro
SEED_GESTIONNAIRE_EMAIL=gestionnaire@stockpro.local
SEED_GESTIONNAIRE_PASSWORD=change_me_gestionnaire_password
SEED_OBSERVATEUR_NOM=Observateur StockPro
SEED_OBSERVATEUR_EMAIL=observateur@stockpro.local
SEED_OBSERVATEUR_PASSWORD=change_me_observateur_password
