# =============================================================
# infra/.env — variables pour le conteneur MySQL (docker-compose)
# Copier ce fichier en .env et renseigner les valeurs réelles.
# Ne jamais committer .env dans le dépôt.
# =============================================================

# Mot de passe root MySQL (utilisé uniquement par le conteneur)
MYSQL_ROOT_PASSWORD=changeme_root

# Nom de la base de données créée automatiquement au premier démarrage
MYSQL_DATABASE=stock_app_db

# Compte applicatif utilisé par le backend pour se connecter
MYSQL_USER=stockpro_user
MYSQL_PASSWORD=changeme_password

# =============================================================
# Variables backend (référence — à positionner dans le shell ou
# dans backend/src/main/resources/application-local.properties)
# Les valeurs par défaut dans application-dev.properties sont
# déjà compatibles avec le docker-compose ci-dessus si vous
# utilisez les mêmes valeurs MYSQL_USER / MYSQL_PASSWORD.
# =============================================================

# DB_HOST=127.0.0.1
# DB_PORT=3307
# DB_NAME=stock_app_db
# DB_USERNAME=stockpro_user
# DB_PASSWORD=changeme_password

# Clé de signature JWT — à changer impérativement en production
# DB_HOST, DB_PORT, DB_NAME, DB_USERNAME, DB_PASSWORD, JWT_SECRET,
# STOCKPRO_DEMO_DATA sont passés directement comme variables d'env
# au processus Spring Boot, pas via docker-compose.
# JWT_SECRET=votre_cle_base64_minimum_32_caracteres

# Activer (true) ou désactiver (false) le chargement des données de démo
# STOCKPRO_DEMO_DATA=true
