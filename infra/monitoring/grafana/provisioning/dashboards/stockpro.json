{
  "title": "StockPro — Observabilité",
  "uid": "stockpro-observability",
  "version": 1,
  "schemaVersion": 38,
  "tags": ["stockpro"],
  "timezone": "browser",
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "30s",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Requêtes HTTP par code de statut",
      "description": "Taux de requêtes entrantes par statut HTTP sur les 5 dernières minutes",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by(status) (rate(http_server_requests_seconds_count{job=\"stockpro-backend\"}[5m]))",
          "legendFormat": "HTTP {{ status }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Latence des requêtes (avg et p95)",
      "description": "Latence moyenne et au 95e percentile des requêtes HTTP",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_sum{job=\"stockpro-backend\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"stockpro-backend\"}[5m]))",
          "legendFormat": "Latence moyenne"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by(le) (rate(http_server_requests_seconds_bucket{job=\"stockpro-backend\"}[5m])))",
          "legendFormat": "Latence p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Mémoire heap JVM utilisée",
      "description": "Consommation mémoire heap en octets",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(jvm_memory_used_bytes{job=\"stockpro-backend\", area=\"heap\"})",
          "legendFormat": "Heap utilisée"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "max": 1073741824,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 536870912 },
              { "color": "red", "value": 858993459 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Threads JVM actifs",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_threads_live_threads{job=\"stockpro-backend\"}",
          "legendFormat": "Threads"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Backend opérationnel",
      "description": "1 = backend accessible par Prometheus, 0 = backend down",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"stockpro-backend\"}",
          "legendFormat": "État"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Uptime backend",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "process_uptime_seconds{job=\"stockpro-backend\"}",
          "legendFormat": "Uptime"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Mouvements de stock (ENTREE / SORTIE) par heure",
      "description": "Nombre cumulé de mouvements acceptés, ventilé par type",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "increase(stockpro_mouvements_total{job=\"stockpro-backend\", type=\"ENTREE\"}[1h])",
          "legendFormat": "ENTREE / heure"
        },
        {
          "refId": "B",
          "expr": "increase(stockpro_mouvements_total{job=\"stockpro-backend\", type=\"SORTIE\"}[1h])",
          "legendFormat": "SORTIE / heure"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Rejets de mouvements (stock insuffisant / capacité dépassée)",
      "description": "Mouvements refusés par raison métier sur 5 minutes glissantes",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "increase(stockpro_mouvements_rejets_total{job=\"stockpro-backend\", raison=\"stock_insuffisant\"}[5m])",
          "legendFormat": "Stock insuffisant"
        },
        {
          "refId": "B",
          "expr": "increase(stockpro_mouvements_rejets_total{job=\"stockpro-backend\", raison=\"capacite_depassee\"}[5m])",
          "legendFormat": "Capacité dépassée"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Rejets rate limit",
      "description": "Requêtes rejetées par le filtre de rate limiting, regroupées par endpoint logique",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by(endpoint) (increase(stockpro_rate_limit_rejections_total{job=\"stockpro-backend\"}[5m]))",
          "legendFormat": "{{ endpoint }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "color": { "mode": "palette-classic" }
        }
      }
    }
  ]
}
