# =============================================================
# .env — variables pour le docker-compose racine (stack complète)
# Copier ce fichier en .env et renseigner les valeurs réelles.
# Ne jamais committer .env dans le dépôt.
# =============================================================

# ── MySQL ────────────────────────────────────────────────────────────────────

# Mot de passe root du conteneur MySQL (interne, non exposé)
MYSQL_ROOT_PASSWORD=changeme_root

# Nom de la base créée automatiquement au premier démarrage
MYSQL_DATABASE=stock_app_db

# Compte applicatif utilisé par le backend
MYSQL_USER=stockpro
MYSQL_PASSWORD=changeme_password

# ── Backend Spring Boot ───────────────────────────────────────────────────────

# Clé de signature JWT en Base64 (minimum 32 caractères avant encodage)
# Générer : openssl rand -base64 32
JWT_SECRET=changeme_jwt_secret_base64_minimum_32_chars

# true  → charge les données de démo tunisiennes au démarrage
# false → base vide, compte admin seul
STOCKPRO_DEMO_DATA=true
